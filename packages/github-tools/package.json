{
  "name": "@github-tools/sdk",
  "version": "1.7.0",
  "description": "GitHub tools for the Vercel AI SDK, wrap GitHub's API as AI SDK tools ready to plug into any agent",
  "author": "HugoRCD <hugo.richard@vercel.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vercel-labs/github-tools.git",
    "directory": "packages/github-tools"
  },
  "homepage": "https://github.com/vercel-labs/github-tools",
  "bugs": {
    "url": "https://github.com/vercel-labs/github-tools/issues"
  },
  "type": "module",
  "sideEffects": [
    "./dist/agents-*.mjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./workflow": {
      "types": "./dist/workflow.d.mts",
      "import": "./dist/workflow.mjs"
    },
    "./eve": {
      "types": "./dist/eve.d.mts",
      "import": "./dist/eve.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "ai",
    "ai-sdk",
    "github",
    "tools",
    "agent",
    "workflow",
    "durable"
  ],
  "license": "MIT",
  "dependencies": {
    "octokit": "^5.0.5"
  },
  "peerDependencies": {
    "@ai-sdk/workflow": "^1.0.16",
    "@workflow/ai": "^4.1.2",
    "ai": "^6.0.97 || ^7.0.0",
    "eve": "^0.19.0",
    "workflow": "^4.5.0",
    "zod": "^4.3.6"
  },
  "peerDependenciesMeta": {
    "workflow": {
      "optional": true
    },
    "@ai-sdk/workflow": {
      "optional": true
    },
    "@workflow/ai": {
      "optional": true
    },
    "eve": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/workflow": "^1.0.16",
    "@ai-sdk/provider": "^4.0.2",
    "@ai-sdk/provider-utils": "^5.0.5",
    "@types/node": "^25.6.0",
    "ai": "^7.0.0",
    "eslint": "^10.3.0",
    "eve": "^0.19.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^3.2.6"
  },
  "packageManager": "pnpm@10.30.2",
  "publishConfig": {
    "access": "public"
  }
}
