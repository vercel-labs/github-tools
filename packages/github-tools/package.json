{
  "name": "@github-tools/sdk",
  "version": "1.4.0",
  "description": "GitHub tools for the Vercel AI SDK, wrap GitHub's API as AI SDK tools ready to plug into any agent",
  "author": "HugoRCD <hugo.richard@vercel.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vercel-labs/github-tools.git",
    "directory": "packages/github-tools"
  },
  "homepage": "https://github.com/vercel-labs/github-tools",
  "bugs": {
    "url": "https://github.com/vercel-labs/github-tools/issues"
  },
  "type": "module",
  "sideEffects": [
    "./dist/agents-*.mjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./workflow": {
      "types": "./dist/workflow.d.mts",
      "import": "./dist/workflow.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "ai-sdk",
    "github",
    "tools",
    "agent",
    "workflow",
    "durable"
  ],
  "license": "MIT",
  "dependencies": {
    "octokit": "^5.0.5"
  },
  "peerDependencies": {
    "ai": "^6.0.97",
    "zod": "^4.3.6",
    "workflow": "^4.2.0-beta.76",
    "@workflow/ai": "^4.1.0-beta.60"
  },
  "peerDependenciesMeta": {
    "workflow": {
      "optional": true
    },
    "@workflow/ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "eslint": "^9.19.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.24.0"
  },
  "packageManager": "pnpm@10.30.2",
  "publishConfig": {
    "access": "public"
  }
}
