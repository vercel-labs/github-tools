{
  "name": "@github-tools/eve-extension",
  "version": "0.1.0",
  "description": "GitHub tools for eve, distributed as a mountable eve extension (https://eve.dev/docs/extensions)",
  "author": "HugoRCD <hugo.richard@vercel.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vercel-labs/github-tools.git",
    "directory": "packages/github-tools-eve-extension"
  },
  "homepage": "https://github-tools.com",
  "bugs": {
    "url": "https://github.com/vercel-labs/github-tools/issues"
  },
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "eve": {
    "extension": {
      "source": "./extension",
      "dist": "./dist/extension"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "default": "./dist/tools/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "eve extension build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "eve",
    "eve-extension",
    "github",
    "tools",
    "agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@github-tools/sdk": "workspace:*",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@vercel/connect": ">=0.3.2",
    "eve": "*"
  },
  "peerDependenciesMeta": {
    "@vercel/connect": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vercel/connect": "^0.4.2",
    "eslint": "^10.3.0",
    "eve": "^0.26.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "packageManager": "pnpm@10.30.2",
  "publishConfig": {
    "access": "public"
  }
}
